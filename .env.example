# ============================================================
# UrbanMove — Environment Variables Template
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# ── GCP ─────────────────────────────────────────────────────
GCP_PROJECT_ID=urbanmove-project-493010
GCP_REGION=us-central1
GCP_PROJECT_NUMBER=72038880424

# ── Google Maps ─────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ── Firebase Web Config ──────────────────────────────────────
# Get from: console.firebase.google.com → Project Settings → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=urbanmove-project-493010.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=urbanmove-project-493010
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=urbanmove-project-493010.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=72038880424
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# ── Service URLs (filled after terraform apply) ──────────────
NEXT_PUBLIC_USER_SERVICE_URL=https://user-service-HASH-uc.a.run.app
NEXT_PUBLIC_ROUTING_ENGINE_URL=https://routing-engine-HASH-uc.a.run.app
NEXT_PUBLIC_ANALYTICS_SERVICE_URL=https://analytics-service-HASH-uc.a.run.app

# ── Pub/Sub ──────────────────────────────────────────────────
PUBSUB_TOPIC_RAW=urbanmove-raw-events
PUBSUB_TOPIC_DEADLETTER=urbanmove-dead-letter

# ── BigQuery ─────────────────────────────────────────────────
BIGQUERY_DATASET=urbanmove
BIGQUERY_TABLE=mobility_events

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=https://mlflow-server-HASH-uc.a.run.app
GCS_MLFLOW_BUCKET=urbanmove-mlflow-artifacts

# ── Local Docker Compose ─────────────────────────────────────
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
FIRESTORE_EMULATOR_HOST=firestore-emulator:8080
